{
  "name": "check-tests",
  "version": "0.4.1",
  "description": "Static analysis for tests. Prints all tests in console and fails when exclusive or skipped tests found.",
  "main": "index.js",
  "keywords": [
    "testing",
    "babel",
    "typescript",
    "static analysis",
    "cypress.io",
    "codeceptjs",
    "protractor",
    "mocha",
    "jest"
  ],
  "homepage": "https://testomat.io",
  "license": "MIT",
  "repository": "https://github.com/testomatio/check-tests",
  "author": {
    "name": "DavertMik",
    "email": "davert@codegyre.com",
    "url": "https://testomat.io"
  },
  "bin": {
    "check-tests": "./bin/check.js"
  },
  "dependencies": {
    "@actions/core": "^1.2.6",
    "@actions/exec": "^1.0.4",
    "@actions/github": "^4.0.0",
    "@actions/io": "^1.1.0",
    "@actions/tool-cache": "^1.6.1",
    "@babel/core": "^7.13.15",
    "@babel/parser": "^7.13.15",
    "@babel/plugin-transform-typescript": "^7.13.0",
    "array-compare": "^2.0.0",
    "babel-traverse": "^6.26.0",
    "chalk": "^4.1.0",
    "commander": "^7.2.0",
    "glob": "^7.1.6",
    "object-hash": "^2.1.1"
  },
  "devDependencies": {
    "chai": "^4.3.4",
    "dotenv": "^8.2.0",
    "eslint": "^7.24.0",
    "eslint-config-airbnb": "^18.2.1",
    "husky": "^6.0.0",
    "mocha": "^8.3.2",
    "prettier": "^2.2.1",
    "pretty-quick": "^3.1.0"
  },
  "scripts": {
    "check": "node -r dotenv/config bin/check.js",
    "run": "node -r dotenv/config index.js",
    "test": "mocha tests/**_test.js",
    "lint": "eslint 'src/**/*.js' --fix",
    "pretty-quick": "pretty-quick --staged",
    "prepare": "husky install"
  }
}
